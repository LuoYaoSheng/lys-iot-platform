# ========================================
# IoT Platform Core 环境配置示例
# 作者: 罗耀生
# 日期: 2025-12-16
# ========================================
#
# 使用说明:
# 1. 复制此文件为 .env
# 2. 根据实际环境修改配置值
# 3. 开发环境可使用 Natapp 内网穿透
#
# ========================================

# ==================== 服务器配置 ====================
# HTTP服务监听端口
SERVER_PORT=48080

# ==================== 数据库配置 ====================
# MySQL数据库连接信息
DB_HOST=localhost
DB_PORT=44306                    # Docker映射端口，容器内部3306
DB_USER=iot_user
DB_PASSWORD=iot123456            # 修改为安全密码
DB_NAME=iot_platform

# ==================== Redis配置 ====================
# Redis缓存服务器
REDIS_HOST=localhost
REDIS_PORT=47379                 # Docker映射端口，容器内部6379

# ==================== MQTT配置 ====================
# MQTT Broker (后端服务连接)
MQTT_BROKER=localhost
MQTT_PORT=42883                  # Docker映射端口，容器内部1883

# MQTT Broker External (设备连接地址)
# 开发环境: 使用Natapp穿透域名
# 生产环境: 使用公网IP或域名
MQTT_BROKER_EXTERNAL=2e9f6a4233617225.natapp.cc

# 说明:
# - MQTT_BROKER: 后端服务连接EMQX使用（Docker容器内通信）
# - MQTT_BROKER_EXTERNAL: ESP32设备连接使用（需要外网可访问）
# - 开发时使用Natapp内网穿透，将本机42883映射到公网
# - 生产环境改为实际的MQTT服务器地址

# ==================== JWT配置 ====================
# JWT密钥和过期时间
JWT_SECRET=iot-platform-secret-key-2025    # 修改为随机字符串
JWT_EXPIRE_HOURS=24                        # Token过期时间（小时）

# ==================== EMQX管理API ====================
# EMQX Dashboard API (用于查询设备在线状态)
EMQX_API_URL=http://localhost:49084
EMQX_API_USERNAME=710045de74f1fc21        # EMQX API Key
EMQX_API_PASSWORD=QQyFuoB0D0j5aibFTInxsWeA33hYTrygcnHqWJ0DSLL  # EMQX Secret Key
EMQX_SYNC_INTERVAL=5                       # 设备状态同步间隔（分钟）

# 说明:
# - API Key在EMQX Dashboard中创建: http://localhost:49084
# - 路径: 系统 -> API密钥 -> 创建
# - 需要勾选权限: clients:read, subscriptions:read

# ========================================
# 配置示例场景
# ========================================
#
# 场景1: 本地开发（无需外网访问）
# MQTT_BROKER_EXTERNAL=localhost
#
# 场景2: Natapp内网穿透（推荐开发使用）
# MQTT_BROKER_EXTERNAL=your-subdomain.natapp.cc
# 运行: natapp -authtoken=your_token -subdomain=your-subdomain -proto=tcp -lport=42883
#
# 场景3: 生产部署（云服务器）
# MQTT_BROKER_EXTERNAL=your-domain.com 或 公网IP
#
# ========================================
