# ========================================
# IoT Platform Core 环境配置 (简化版)
# 作者: 罗耀生
# 日期: 2026-01-06
# 说明: 内置MQTT Broker，无需外部EMQX
# ========================================

# ==================== 服务器配置 ====================
SERVER_PORT=48080

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=44306
DB_USER=iot_user
DB_PASSWORD=YOUR_DB_PASSWORD_HERE   # ⚠️ 请修改
DB_NAME=iot_platform

# ==================== MQTT配置 (内置Broker) ====================
MQTT_PORT=1883           # TCP端口
MQTT_WS_PORT=8083        # WebSocket端口

# 设备连接地址 (改为你的IP或域名)
# 开发环境: localhost 或 Natapp穿透域名
# 生产环境: 公网IP或域名
MQTT_BROKER_EXTERNAL=localhost

# ==================== JWT配置 ====================
JWT_SECRET=YOUR_JWT_SECRET_HERE   # ⚠️ 请修改为随机字符串
JWT_EXPIRE_HOURS=24
