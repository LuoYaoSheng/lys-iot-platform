# Open IoT Platform - .gitignore

# ========================================
# Release 文件（通过 GitHub Releases 上传，不提交到仓库）
# ========================================
releases/
smartlink-hub/releases/

# ========================================
# 内容规划（个人创作笔记，不提交到仓库）
# ========================================
docs/内容规划/

# ========================================
# 编译产物
# ========================================
*.exe
*.out
*.test
*.o
*.a
*.elf
*.map

# ========================================
# IDE
# ========================================
.idea/
.vscode/
*.swp
*.swo
.claude/

# ========================================
# 依赖
# ========================================
vendor/
node_modules/
.pub-cache/
.build/

# ========================================
# 日志
# ========================================
*.log
logs/
run.log

# ========================================
# 配置文件（敏感信息）
# ========================================
.env
.env.local
.env.production
*.secret

# ========================================
# 备份文件
# ========================================
backups/
*.dump
*.bak.sql

# ========================================
# Docker 数据卷
# ========================================
mysql_data/
redis_data/
emqx_data/

# ========================================
# 临时文件
# ========================================
*.tmp
*.bak
*.pid
.DS_Store
Thumbs.db

# ========================================
# PlatformIO
# ========================================
.pio/
*.pio.yml
.clang_complete
.gcc-flags.json

# ========================================
# Flutter/Dart
# ========================================
**/*.dart.js
**/*.dart.js.map
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/

# Android Certificates (NEVER COMMIT)
backup/android-certificates/
mobile-app/android/key.properties
mobile-app/android/keystore/*.jks
